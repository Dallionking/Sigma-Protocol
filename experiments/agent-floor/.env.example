# =============================================================================
# AgentFloor Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control

# =============================================================================
# Server Configuration
# =============================================================================

# Colyseus WebSocket server port (default: 2567)
COLYSEUS_PORT=2567

# Next.js server port (default: 3000)
# PORT=3000

# =============================================================================
# LLM Provider API Keys
# =============================================================================
# Add API keys for the providers you want to use.
# Agents can be configured to use different providers/models.

# Anthropic (Claude models)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (GPT models)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google AI (Gemini models)
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# OpenRouter (unified API for multiple models)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# XAI (Grok models)
# Get your key at: https://console.x.ai/
XAI_API_KEY=

# =============================================================================
# Claude Code CLI Configuration
# =============================================================================
# Uses your Claude Max subscription for agent completions

# Path to the Claude Code CLI executable
# macOS default: /usr/local/bin/claude or ~/.claude/local/claude
# If using npm global install: npx claude
CLAUDE_CODE_PATH=/usr/local/bin/claude

# =============================================================================
# Local LLM Configuration (Ollama)
# =============================================================================

# Ollama server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Default Ollama model to use
OLLAMA_MODEL=llama3.2

# =============================================================================
# Voice Synthesis (ElevenLabs)
# =============================================================================
# Enables agents to speak their messages aloud

# ElevenLabs API key
# Get your key at: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# Default voice ID for agents without specific voice assignment
# ELEVENLABS_DEFAULT_VOICE_ID=

# =============================================================================
# GitHub Integration
# =============================================================================
# Enables agents to create branches, commits, and PRs

# GitHub Personal Access Token with repo scope
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Default repository for agent operations (owner/repo format)
# GITHUB_DEFAULT_REPO=

# =============================================================================
# External Notifications (Optional)
# =============================================================================

# Slack webhook URL for notifications
# SLACK_WEBHOOK_URL=

# Discord webhook URL for notifications
# DISCORD_WEBHOOK_URL=

# =============================================================================
# Development Settings
# =============================================================================

# Enable debug logging (true/false)
# DEBUG=false

# Mock mode - run without real API calls (true/false)
# MOCK_MODE=true

# Log level (debug, info, warn, error)
# LOG_LEVEL=info
