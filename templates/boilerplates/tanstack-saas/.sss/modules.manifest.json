{
  "$schema": "../../../schemas/modules-manifest.schema.json",
  "template": "tanstack-saas",
  "platform": "web",
  "framework": "tanstack-start",
  "modules": {
    "marketing": {
      "enabled": true,
      "files": [
        "src/routes/(marketing)/index.tsx",
        "src/routes/(marketing)/pricing.tsx",
        "src/routes/(marketing)/_layout.tsx",
        "src/modules/marketing/"
      ],
      "navItems": [
        { "label": "Pricing", "href": "/pricing", "location": "header" }
      ],
      "envVars": []
    },
    "auth": {
      "enabled": true,
      "files": [
        "src/routes/(auth)/login.tsx",
        "src/routes/(auth)/signup.tsx",
        "src/routes/(auth)/forgot-password.tsx",
        "src/routes/(auth)/_layout.tsx",
        "src/modules/auth/",
        "src/hooks/use-auth.ts",
        "src/lib/supabase/"
      ],
      "navItems": [
        { "label": "Login", "href": "/login", "location": "header-right" }
      ],
      "envVars": [
        "VITE_SUPABASE_URL",
        "VITE_SUPABASE_ANON_KEY"
      ]
    },
    "dashboard": {
      "enabled": true,
      "files": [
        "src/routes/(app)/_layout.tsx",
        "src/routes/(app)/index.tsx",
        "src/modules/dashboard/",
        "src/components/dashboard/"
      ],
      "navItems": [
        { "label": "Dashboard", "href": "/app", "location": "sidebar", "icon": "home" }
      ],
      "envVars": []
    },
    "settings": {
      "enabled": true,
      "files": [
        "src/routes/(app)/settings/index.tsx",
        "src/routes/(app)/settings/_layout.tsx",
        "src/modules/settings/"
      ],
      "navItems": [
        { "label": "Settings", "href": "/app/settings", "location": "sidebar", "icon": "settings" }
      ],
      "envVars": []
    },
    "billing": {
      "enabled": true,
      "files": [
        "src/routes/(app)/billing/index.tsx",
        "src/routes/(app)/billing/_layout.tsx",
        "src/modules/billing/"
      ],
      "navItems": [
        { "label": "Billing", "href": "/app/billing", "location": "sidebar", "icon": "credit-card" }
      ],
      "envVars": [
        "STRIPE_SECRET_KEY"
      ]
    },
    "admin": {
      "enabled": true,
      "files": [
        "src/routes/(app)/admin/index.tsx",
        "src/routes/(app)/admin/_layout.tsx",
        "src/modules/admin/"
      ],
      "navItems": [
        { "label": "Admin", "href": "/app/admin", "location": "sidebar", "icon": "shield", "roleRequired": "admin" }
      ],
      "envVars": []
    },
    "aiChat": {
      "enabled": false,
      "files": [
        "src/routes/(app)/chat/index.tsx",
        "src/routes/(app)/chat/$conversationId.tsx",
        "src/routes/(app)/chat/_layout.tsx",
        "src/modules/ai-chat/"
      ],
      "navItems": [
        { "label": "AI Chat", "href": "/app/chat", "location": "sidebar", "icon": "message-square" }
      ],
      "envVars": [
        "OPENAI_API_KEY"
      ]
    },
    "crudExample": {
      "enabled": false,
      "files": [
        "src/routes/(app)/items/index.tsx",
        "src/routes/(app)/items/$id.tsx",
        "src/modules/crud-example/"
      ],
      "navItems": [
        { "label": "Items", "href": "/app/items", "location": "sidebar", "icon": "list" }
      ],
      "envVars": []
    },
    "errorStates": {
      "enabled": true,
      "files": [
        "src/routes/__root.tsx",
        "src/components/error-states/"
      ],
      "navItems": [],
      "envVars": []
    }
  },
  "sidebarConfig": {
    "location": "left",
    "collapsible": true,
    "sections": [
      {
        "title": null,
        "items": ["dashboard"]
      },
      {
        "title": "Account",
        "items": ["settings", "billing"]
      },
      {
        "title": "System",
        "items": ["admin"]
      }
    ]
  }
}

