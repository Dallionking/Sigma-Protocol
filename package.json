{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "sigma-protocol",
  "version": "1.0.0-alpha.1",
  "description": "Sigma Protocol - Platform-agnostic 13-step product development methodology for AI-assisted development",
  "keywords": [
    "ai",
    "development",
    "methodology",
    "product-development",
    "cursor",
    "claude-code",
    "opencode",
    "agents",
    "prd",
    "startup"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dallionking/sigma-protocol.git"
  },
  "license": "MIT",
  "author": "Sigma Protocol Team",
  "type": "module",
  "main": "cli/sigma-cli.js",
  "bin": {
    "sigma": "cli/sigma-cli.js",
    "sigma-protocol": "cli/sigma-cli.js"
  },
  "scripts": {
    "install:local": "node cli/sigma-cli.js install",
    "build:cursor": "node cli/sigma-cli.js build --platform cursor",
    "build:claude-code": "node cli/sigma-cli.js build --platform claude-code",
    "build:opencode": "node cli/sigma-cli.js build --platform opencode",
    "build:all": "node cli/sigma-cli.js build --platform all",
    "test": "node --test \"cli/__tests__/**/*.test.js\"",
    "lint": "eslint cli/",
    "format": "prettier --write \"**/*.{js,json,yaml,md}\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.50.0",
    "ajv": "^8.17.1",
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "cli-spinners": "^2.9.2",
    "commander": "^12.1.0",
    "e2b": "^1.0.7",
    "figlet": "^1.7.0",
    "fs-extra": "^11.2.0",
    "gradient-string": "^2.0.2",
    "inquirer": "^9.2.23",
    "js-yaml": "^4.1.0",
    "listr2": "^8.0.0",
    "ora": "^8.0.1",
    "terminal-link": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
