import { z } from "zod"
import { revalidatePath } from "next/cache"
import { db } from "@/db/db"
import { tableName } from "@/db/schema"
import { eq, and } from "drizzle-orm"
import { auth } from "@/lib/supabase/auth"

export async function delete[Entity](id: string): Promise<{ success: boolean; error?: string }> {
  try {
    const validated = z.string().uuid().parse(id)
    
    const { user } = await auth()
    if (!user) {
      return { success: false, error: "Unauthorized" }
    }
    
    // Soft delete or hard delete with ownership check
    const result = await db.delete(tableName)
      .where(and(
        eq(tableName.id, validated),
        eq(tableName.userId, user.id)
      ))
      .returning({ id: tableName.id })
    
    if (result.length === 0) {
      return { success: false, error: "Not found or access denied" }
    }
    
    revalidatePath('/path/to/list')
    
    return { success: true }
  } catch (error) {
    return { success: false, error: "Failed to delete" }
  }
}
