# SSS Protocol .gitignore

# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
.turbo/

# IDE and editor
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Environment and secrets
.env
.env.*
.env.local
.env.*.local
*.env

# Sensitive files - NEVER COMMIT
**/OAuth*.json
**/credentials*.json
**/service-account*.json
**/secrets*.json
**/*-key.json
**/*-credentials.json
**/api-key*.json
**/token*.json

# Archives (should never be committed)
*.zip
*.tar.gz
*.tar
*.rar
*.7z

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Testing
coverage/
.nyc_output/

# Caches
.cache/
*.cache
.eslintcache
.prettiercache

# SSS Protocol specific
.sss/
.tracking-db/
*.tracking.json

# Generated platform outputs (use CLI to generate fresh)
# These are generated by: npx sss-protocol build
# .cursor/commands/ is kept in boilerplates but generated elsewhere
# .claude/ is auto-generated
# .opencode/ is auto-generated

# Temporary files
tmp/
temp/
*.tmp
*.temp

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Private/internal content (should never be in public repo)
course/
claude-code/
Inspo/
assets/
docs/notebooklm/
commands-private-archive/

# Personal/internal docs (not for public)
MOBILE_APP_DESIGN_LEARNINGS.md
SIGMAVUE-FRAMEWORK-COMPLIANCE-PROMPT.md
SSS-FULL-METHODOLOGY-REBUILD.md
SKILL.md
*-ANALYSIS-*.md
*-SUMMARY*.md
GAP-ANALYSIS*.md
HOLES-ANALYSIS*.md
PHASE-*-SUMMARY.md
IMPLEMENTATION-SUMMARY.md
CHANGELOG-*.md

# Cursor plans (internal)
.cursor/plans/

# Workspace files (IDE-specific)
*.code-workspace
