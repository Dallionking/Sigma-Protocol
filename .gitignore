# Sigma Protocol .gitignore

# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
.turbo/

# IDE and editor
.idea/
.vscode/
.cursor/projects/
.claude/projects/
*.swp
*.swo
*.code-workspace
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Environment and secrets
.env
.env.*
.env.local
.env.*.local
*.env

# Sensitive files - NEVER COMMIT
**/OAuth*.json
**/credentials*.json
**/service-account*.json
**/secrets*.json
**/*-key.json
**/*-credentials.json
**/api-key*.json
**/token*.json

# Archives (should never be committed)
*.zip
*.tar.gz
*.tar
*.rar
*.7z

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dev-debug.log
logs

# Testing
coverage/
.nyc_output/

# Caches
.cache/
*.cache
.eslintcache
.prettiercache

# Python cache
__pycache__/
*.pyc

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.bak
*~

# Sigma Protocol specific
.sigma/
.tracking-db/
*.tracking.json

# Research & Analysis (not needed by end users)
.sigma/confidence/
docs/research/
docs/analysis/
*-analysis-*.md
*-audit-*.md
gap-analysis-*.json

# Implementation artifacts
validation-*.png
*.local.md
*.local.json

# Orchestration testing (worktrees, logs, session state)
worktrees/
.taskmaster/
mprocs.yaml
streams.json
orchestration-*.log
*.preview-url

# Work-in-progress plugins (not ready for public release)
packages/sigma-protocol-plugin/
packages/sss-harness/
packages/_upstream/

# Generated platform outputs (use CLI to generate fresh)
# These are generated by: npx sigma-protocol build
# .cursor/commands/ is kept in boilerplates but generated elsewhere
# .claude/ is auto-generated
# .opencode/ is auto-generated

# Private/internal content (should never be in public repo)
course/
claude-code/
Inspo/
assets/
docs/notebooklm/
commands-private-archive/

# Research & Transcripts (not for public repo)
Transcripts/
*transcript*
Ralph-wiggum-transcript
marketing-book-research/

# Analysis directories & generated outputs
docs/prds/
docs/sessions/

# Planning & temporary analysis docs
CLI-ENHANCEMENT-ANALYSIS.md
PLAN-UPSTREAM-HARNESS-REFERENCE.md
docs/SSS-AGENT-HARNESS-IMPLEMENTATION-PLAN.md
*-ANALYSIS.md
*IMPLEMENTATION-PLAN*.md

# Personal/internal docs (not for public)
MOBILE_APP_DESIGN_LEARNINGS.md
SIGMAVUE-FRAMEWORK-COMPLIANCE-PROMPT.md
SSS-FULL-METHODOLOGY-REBUILD.md
SKILL.md
*-ANALYSIS-*.md
*-SUMMARY*.md
GAP-ANALYSIS*.md
HOLES-ANALYSIS*.md
PHASE-*-SUMMARY.md
IMPLEMENTATION-SUMMARY.md
CHANGELOG-*.md

# Cursor plans (internal)
.cursor/plans/

# Keep patterns (don't ignore these)
!docs/specs/
!templates/

# Project-level Claude Code / agent config (personal, not distributable)
CLAUDE.md
AGENTS.md

# Legacy agents (deprecated, replaced by commands)
.claude/agents-legacy/

# Build artifacts in packages
packages/*/dist/

# Archived documentation
.archive/
