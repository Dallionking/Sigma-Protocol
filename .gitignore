# SSS Protocol .gitignore

# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
.turbo/

# IDE and editor
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Environment and secrets
.env
.env.*
.env.local
.env.*.local
*.env

# Sensitive files - NEVER COMMIT
**/OAuth*.json
**/credentials*.json
**/service-account*.json
**/secrets*.json
**/*-key.json
**/*-credentials.json

# Archives
*.zip
*.tar.gz
*.rar

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Testing
coverage/
.nyc_output/

# Caches
.cache/
*.cache
.eslintcache
.prettiercache

# SSS Protocol specific
.sss/
.tracking-db/
*.tracking.json

# Generated platform outputs (use CLI to generate fresh)
# These are generated by: npx sss-protocol build
# .cursor/commands/ is kept in boilerplates but generated elsewhere
# .claude/ is auto-generated
# .opencode/ is auto-generated

# Temporary files
tmp/
temp/
*.tmp
*.temp

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

