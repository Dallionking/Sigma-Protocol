# Sigma Protocol .gitignore

# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
.turbo/

# IDE and editor
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Environment and secrets
.env
.env.*
.env.local
.env.*.local
*.env

# Sensitive files - NEVER COMMIT
**/OAuth*.json
**/credentials*.json
**/service-account*.json
**/secrets*.json
**/*-key.json
**/*-credentials.json
**/api-key*.json
**/token*.json

# Archives (should never be committed)
*.zip
*.tar.gz
*.tar
*.rar
*.7z

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Testing
coverage/
.nyc_output/

# Caches
.cache/
*.cache
.eslintcache
.prettiercache

# Sigma Protocol specific
.sigma/
.tracking-db/
*.tracking.json

# Orchestration testing (worktrees, logs, session state)
worktrees/
.taskmaster/
mprocs.yaml
streams.json
orchestration-*.log
*.preview-url

# Work-in-progress plugins (not ready for public release)
packages/sigma-protocol-plugin/
packages/sss-harness/
packages/_upstream/

# Generated platform outputs (use CLI to generate fresh)
# These are generated by: npx sigma-protocol build
# .cursor/commands/ is kept in boilerplates but generated elsewhere
# .claude/ is auto-generated
# .opencode/ is auto-generated

# Temporary files
tmp/
temp/
*.tmp
*.temp

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Private/internal content (should never be in public repo)
course/
claude-code/
Inspo/
assets/
docs/notebooklm/
commands-private-archive/

# Research & Transcripts (not for public repo)
Trasnscripts/
*transcript*
Ralph-wiggum-transcript
marketing-book-research/

# Analysis directories & generated outputs
docs/analysis/
docs/prds/

