### Phase 4: Approval Handling

```typescript
// This function is called when user says "Approved, continue"
async function handleApproval(streamName: string): Promise<void> {
  const stream = `stream-${streamName.toLowerCase()}`;
  
  console.log(`\n✅ Approval received for Stream ${streamName.toUpperCase()}`);
  
  // Find next PRD for this stream
  const config = await loadConfig();
  const streamConfig = config.streams.find(s => 
    s.name.toLowerCase() === streamName.toLowerCase()
  );
  
  if (!streamConfig) {
    console.log('Stream not found');
    return;
  }
  
  // Find completed PRDs
  const completedPRDs = progress.completedPRDs;
  const nextPRD = streamConfig.prds.find(p => !completedPRDs.includes(p));
  
  if (nextPRD) {
    // Assign next PRD
    await sendMessage({
      from: 'orchestrator',
      to: stream,
      type: 'prd_assignment',
      payload: {
        prd: nextPRD,
        worktree: streamConfig.worktree
      }
    });
    
    console.log(`\n📤 Assigned next PRD to Stream ${streamName.toUpperCase()}: ${nextPRD}`);
    voiceNotify(`Stream ${streamName} starting ${nextPRD}`);
    
    updateStreamStatus(stream, 'working');
  } else {
    console.log(`\n✅ Stream ${streamName.toUpperCase()} has completed all assigned PRDs`);
    voiceNotify(`Stream ${streamName} has completed all assigned work`);
    
    updateStreamStatus(stream, 'done');
  }
}
