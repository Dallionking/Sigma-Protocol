async function handleStoryComplete(msg: AgentMessage): Promise<void> {
  const { from, payload } = msg;
  const { prd, story_id, story_title } = payload;
  
  console.log(`\n📬 Stream ${from}: Story complete - ${story_id} (${story_title})`);
  
  // Run quick verification
  const verified = await runStoryVerification(story_id);
  
  if (verified) {
    console.log(`✅ Story ${story_id} verified`);
    
    // Tell stream to continue
    await sendMessage({
      from: 'orchestrator',
      to: from,
      type: 'continue',
      payload: { message: 'Story verified. Proceed to next.' }
    });
  } else {
    console.log(`⚠️ Story ${story_id} needs fixes`);
    
    // Tell stream about issues
    await sendMessage({
      from: 'orchestrator',
      to: from,
      type: 'revision_needed',
      payload: { 
        story_id,
        issues: verified.issues,
        message: 'Please address these issues before continuing.'
      }
    });
  }
  
  updateProgress({ 
    streams: { [from]: { lastStory: story_id, status: 'working' } }
  });
}

