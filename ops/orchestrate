## ⚡ Spawn Flow (New in v2.0)

When invoked mid-session with `--quick` or `--forks`:

```typescript
async function spawnOrchestration(params): Promise<void> {
  // 1. Detect backend
  const backend = params.backend || detectBackend();
  // Order: iTerm2 → tmux → Task subagents
  
  console.log(`Backend: ${backend}`);
  
  // 2. Determine configuration
  const streams = params.streams || 1;  // Default: 1 stream for mid-session
  const forks = params.forks || params.quick || 2;
  const prd = params.prd || 'current-context';
  
  // 3. Spawn based on backend
  switch (backend) {
    case 'iterm':
      // Use iTerm2 AppleScript to create tabs + panes
      await launchItermTabs({ streams, forks, prd });
      break;
      
    case 'tmux':
      // Use tmux windows + panes
      await launchTmuxSession({ streams, forks, prd });
      break;
      
    case 'task':
      // Use Task subagents (in-process)
      await launchTaskSubagents({ streams, forks, prd });
      break;
  }
  
  // 4. Install hooks in each fork
  for (const fork of allForks) {
    await installHooksInWorktree(fork.workdir, fork.id, projectRoot, 'fork');
  }
  
  // 5. Install orchestrator hooks in current directory
  await installHooksInWorktree(projectRoot, 'orchestrator', projectRoot, 'orchestrator');
  
  // 6. Create CLAUDE.md files
  await generateClaudeMdFiles(config);
  
  console.log(`
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
✅ ORCHESTRATION SPAWNED
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Backend: ${backend}
Streams: ${streams}
Forks per stream: ${forks}
Total agents: ${1 + streams * forks}

Hooks installed:
- Fork Stop: auto-report + heartbeat
- Orchestrator Stop: auto-poll inbox

You are now the orchestrator.
Check your inbox for fork updates.
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  `);
}

function detectBackend(): 'iterm' | 'tmux' | 'task' {
  // Check iTerm2 first
  if (process.platform === 'darwin') {
    try {
      const result = execSync('osascript -e \'application "iTerm2" is running\'');
      if (result.toString().trim() === 'true') return 'iterm';
      // Check if iTerm2 is installed
      if (fs.existsSync('/Applications/iTerm.app')) return 'iterm';
    } catch {}
  }
  
  // Check tmux
  try {
    execSync('which tmux');
    return 'tmux';
  } catch {}
  
  // Fallback to Task subagents
  return 'task';
}
```

