## 🔄 Core Workflow

### Phase 1: Initialize Streams

```typescript
interface StreamAssignment {
  name: string;        // A, B, C, D
  prds: string[];      // ["F001", "F005"]
  worktree: string;    // "stream-a"
  currentPRD?: string;
  status: 'idle' | 'working' | 'awaiting_verification' | 'prd_complete' | 'blocked';
}

async function initializeStreams(config: StreamConfig): Promise<void> {
  console.log('\n📡 Initializing stream connections...\n');
  
  for (const stream of config.streams) {
    // Wait for stream registration via mcp_agent_mail
    console.log(`Waiting for Stream ${stream.name} to register...`);
    
    // Send initial assignment
    await sendMessage({
      from: 'orchestrator',
      to: `stream-${stream.name.toLowerCase()}`,
      type: 'prd_assignment',
      payload: {
        prd: stream.prds[0],
        worktree: stream.worktree,
        executeOrder: getExecutionOrder(stream.prds[0])
      }
    });
    
    console.log(`✅ Stream ${stream.name} assigned: ${stream.prds[0]}`);
  }
  
  updateProgress({ currentPhase: 'executing' });
  voiceNotify('All streams initialized. Starting PRD execution.');
}
```

### Phase 2: Monitor Progress

```typescript
async function monitorLoop(): Promise<void> {
  console.log('\n🔄 Entering monitoring loop...\n');
  console.log('Listening for stream messages...\n');
  
  while (true) {
    // Check inbox for messages from streams
    const messages = await checkInbox();
    
    for (const msg of messages) {
      switch (msg.type) {
        case 'story_complete':
          await handleStoryComplete(msg);
          break;
          
        case 'prd_complete':
          await handlePRDComplete(msg);
          break;
          
        case 'blocked':
          await handleBlocked(msg);
          break;
          
        case 'error':
          await handleError(msg);
          break;
          
        case 'status_update':
          updateStreamStatus(msg.from, msg.payload.status);
          break;
      }
    }
    
    // Check for all streams complete
    if (allStreamsComplete()) {
      await handleAllComplete();
      break;
    }
    
    // Brief pause before next check
    await sleep(1000);
  }
}
```

