## 🔍 Freshness Checking (v3.0.0)

### Staleness Detection

```typescript
interface FreshnessReport {
  overallScore: number; // 0-100
  staleDocuments: StaleDocument[];
  freshDocuments: string[];
  recommendations: string[];
  lastFullUpdate: string;
}

interface StaleDocument {
  path: string;
  lastUpdated: string;
  relatedCodeChanges: {
    file: string;
    lastChanged: string;
    commits: string[];
  }[];
  staleDays: number;
  priority: 'high' | 'medium' | 'low';
}

async function checkFreshness(): Promise<FreshnessReport> {
  console.log('🔍 Checking documentation freshness...');
  
  // Get all documentation files
  const docFiles = await glob('**/*.md', { ignore: ['node_modules/**'] });
  
  // Get all code files
  const codeFiles = await glob('**/*.{ts,tsx,js,jsx}', { ignore: ['node_modules/**', '.next/**'] });
  
  const staleDocuments: StaleDocument[] = [];
  const freshDocuments: string[] = [];
  
  // Build code-to-doc mapping
  const codeToDocs = buildCodeToDocsMapping();
  
  for (const docFile of docFiles) {
    const docLastModified = await getLastModified(docFile);
    const relatedCode = codeToDocs[docFile] || [];
    
    let isStale = false;
    const codeChanges = [];
    
    for (const codeFile of relatedCode) {
      const codeLastModified = await getLastModified(codeFile);
      
      if (codeLastModified > docLastModified) {
        isStale = true;
        const commits = await getCommitsSince(codeFile, docLastModified);
        codeChanges.push({
          file: codeFile,
          lastChanged: codeLastModified,
          commits,
        });
      }
    }
    
    if (isStale) {
      const staleDays = daysDiff(docLastModified, new Date());
      staleDocuments.push({
        path: docFile,
        lastUpdated: docLastModified,
        relatedCodeChanges: codeChanges,
        staleDays,
        priority: staleDays > 30 ? 'high' : staleDays > 14 ? 'medium' : 'low',
      });
    } else {
      freshDocuments.push(docFile);
    }
  }
  
  // Calculate overall score
  const totalDocs = docFiles.length;
  const freshCount = freshDocuments.length;
  const overallScore = Math.round((freshCount / totalDocs) * 100);
  
  return {
    overallScore,
    staleDocuments,
    freshDocuments,
    recommendations: generateFreshnessRecommendations(staleDocuments),
    lastFullUpdate: new Date().toISOString(),
  };
}

function buildCodeToDocsMapping(): Record<string, string[]> {
  return {
    'docs/API-REFERENCE.md': ['app/api/**/*.ts', 'actions/**/*.ts'],
    'docs/SCHEMA.md': ['db/schema/**/*.ts'],
    'docs/ARCHITECTURE.md': ['lib/**/*.ts', 'app/**/layout.tsx'],
    'README.md': ['package.json', 'next.config.js'],
  };
}
```

