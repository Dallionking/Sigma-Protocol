## 📈 Trend Tracking (v3.0.0)

### Documentation Metrics History

```typescript
interface DocsMetrics {
  timestamp: string;
  freshnessScore: number;
  qualityScore: number;
  completenessScore: number;
  totalDocs: number;
  staleDocs: number;
  issues: number;
}

async function trackMetrics(
  freshness: FreshnessReport,
  quality: QualityReport
): Promise<void> {
  const metricsPath = '/docs/.docs-metrics.json';
  
  let history: DocsMetrics[] = [];
  try {
    history = JSON.parse(await readFile(metricsPath));
  } catch {
    history = [];
  }
  
  const current: DocsMetrics = {
    timestamp: new Date().toISOString(),
    freshnessScore: freshness.overallScore,
    qualityScore: quality.overallScore,
    completenessScore: quality.categories.completeness.score,
    totalDocs: freshness.staleDocuments.length + freshness.freshDocuments.length,
    staleDocs: freshness.staleDocuments.length,
    issues: quality.issues.length,
  };
  
  history.push(current);
  
  // Keep last 30 entries
  if (history.length > 30) {
    history = history.slice(-30);
  }
  
  await writeFile(metricsPath, JSON.stringify(history, null, 2));
  
  // Calculate trends
  if (history.length >= 2) {
    const prev = history[history.length - 2];
    const freshnessTrend = current.freshnessScore - prev.freshnessScore;
    const qualityTrend = current.qualityScore - prev.qualityScore;
    
    console.log(`
📈 Documentation Trends
━━━━━━━━━━━━━━━━━━━━━━━
Freshness: ${current.freshnessScore}% (${freshnessTrend >= 0 ? '+' : ''}${freshnessTrend}%)
Quality: ${current.qualityScore}% (${qualityTrend >= 0 ? '+' : ''}${qualityTrend}%)
Stale Docs: ${current.staleDocs} (was ${prev.staleDocs})
Issues: ${current.issues} (was ${prev.issues})
━━━━━━━━━━━━━━━━━━━━━━━
`);
  }
}
```

