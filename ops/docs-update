## 📝 Enhanced Changelog Generation (v3.0.0)

### Git-Based Changelog

```typescript
interface ChangelogEntry {
  version: string;
  date: string;
  changes: {
    type: 'feat' | 'fix' | 'docs' | 'refactor' | 'perf' | 'test' | 'chore' | 'breaking';
    scope?: string;
    message: string;
    commit: string;
    author: string;
  }[];
}

async function generateChangelog(
  options: { since?: string; until?: string } = {}
): Promise<ChangelogEntry[]> {
  console.log('📝 Generating changelog from git history...');
  
  // Get git log
  const gitLogCmd = `git log --pretty=format:"%H|%an|%ad|%s" --date=short ${options.since ? `--since="${options.since}"` : ''} ${options.until ? `--until="${options.until}"` : ''}`;
  
  const gitLog = await runCommand(gitLogCmd);
  const commits = gitLog.split('\n').filter(Boolean);
  
  const changes: ChangelogEntry['changes'] = [];
  
  for (const commit of commits) {
    const [hash, author, date, message] = commit.split('|');
    
    // Parse conventional commit format
    const conventionalMatch = message.match(/^(\w+)(?:\(([^)]+)\))?: (.+)$/);
    
    if (conventionalMatch) {
      const [, type, scope, msg] = conventionalMatch;
      changes.push({
        type: type as any,
        scope,
        message: msg,
        commit: hash.slice(0, 7),
        author,
      });
    } else {
      // Non-conventional commit
      changes.push({
        type: 'chore',
        message,
        commit: hash.slice(0, 7),
        author,
      });
    }
  }
  
  // Group by version (based on tags or time periods)
  const versions = await groupByVersion(changes);
  
  return versions;
}

function formatChangelog(entries: ChangelogEntry[]): string {
  let changelog = `# Changelog

All notable changes to this project will be documented in this file.

The format is based on [Keep a Changelog](https://keepachangelog.com/en/1.0.0/),
and this project adheres to [Semantic Versioning](https://semver.org/spec/v2.0.0.html).

`;

  for (const entry of entries) {
    changelog += `## [${entry.version}] - ${entry.date}\n\n`;
    
    // Group by type
    const types = {
      breaking: '### ⚠️ BREAKING CHANGES',
      feat: '### ✨ Features',
      fix: '### 🐛 Bug Fixes',
      perf: '### ⚡ Performance',
      docs: '### 📚 Documentation',
      refactor: '### ♻️ Refactoring',
      test: '### 🧪 Tests',
      chore: '### 🔧 Maintenance',
    };
    
    for (const [type, header] of Object.entries(types)) {
      const typeChanges = entry.changes.filter(c => c.type === type);
      if (typeChanges.length > 0) {
        changelog += `${header}\n\n`;
        for (const change of typeChanges) {
          const scope = change.scope ? `**${change.scope}:** ` : '';
          changelog += `- ${scope}${change.message} ([${change.commit}](commit/${change.commit})) - @${change.author}\n`;
        }
        changelog += '\n';
      }
    }
  }
  
  return changelog;
}
```

