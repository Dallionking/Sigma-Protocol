  severity: 'high' | 'medium' | 'low';
  message: string;
  line?: number;
}

async function analyzeQuality(): Promise<QualityReport> {
  console.log('📊 Analyzing documentation quality...');
  
  const issues: QualityIssue[] = [];
  const categories = {
    completeness: await analyzeCompleteness(),
    readability: await analyzeReadability(),
    accuracy: await analyzeAccuracy(),
    organization: await analyzeOrganization(),
    examples: await analyzeExamples(),
  };
  
  // Calculate overall score
  const weights = {
    completeness: 0.25,
    readability: 0.20,
    accuracy: 0.25,
    organization: 0.15,
    examples: 0.15,
  };
  
  const overallScore = Object.entries(categories).reduce((sum, [key, cat]) => {
    return sum + cat.score * weights[key];
  }, 0);
  
  return {
    overallScore: Math.round(overallScore),
    categories,
    issues: collectAllIssues(categories),
    recommendations: generateQualityRecommendations(categories),
  };
}
```

### Completeness Analysis

```typescript
async function analyzeCompleteness(): Promise<CategoryScore> {
  const requiredDocs = [
    { file: 'README.md', weight: 1.0 },
    { file: 'docs/API-REFERENCE.md', weight: 0.8 },
    { file: 'docs/ARCHITECTURE.md', weight: 0.7 },
    { file: 'docs/SCHEMA.md', weight: 0.6 },
    { file: 'CONTRIBUTING.md', weight: 0.5 },
    { file: 'LICENSE', weight: 0.4 },
  ];
  
  const requiredSections = {
    'README.md': ['Installation', 'Usage', 'Configuration'],
    'docs/API-REFERENCE.md': ['Overview', 'Endpoints', 'Authentication'],
  };
  
  let score = 0;
  let maxScore = 0;
  const issues: string[] = [];
  
  for (const doc of requiredDocs) {
    maxScore += doc.weight * 100;
    
    try {
      const content = await readFile(doc.file);
      score += doc.weight * 50; // File exists
      
      // Check sections
      const sections = requiredSections[doc.file] || [];
      for (const section of sections) {
        if (content.includes(`## ${section}`) || content.includes(`# ${section}`)) {
          score += (doc.weight * 50) / sections.length;
        } else {
          issues.push(`Missing section "${section}" in ${doc.file}`);
        }
      }
    } catch {
      issues.push(`Missing required file: ${doc.file}`);
    }
  }
  
  return {
    score: Math.round((score / maxScore) * 100),
    details: `${requiredDocs.length - issues.filter(i => i.includes('Missing required')).length}/${requiredDocs.length} required docs present`,
    issues,
  };
}
```

### Readability Analysis

```typescript
async function analyzeReadability(): Promise<CategoryScore> {
  const docFiles = await glob('**/*.md', { ignore: ['node_modules/**'] });
  
  let totalScore = 0;
  const issues: string[] = [];
  
  for (const file of docFiles) {
    const content = await readFile(file);
    
    // Calculate Flesch-Kincaid readability
    const fkScore = calculateFleschKincaid(content);
    
    if (fkScore < 30) {
      issues.push(`${file}: Very difficult to read (FK: ${fkScore})`);
    } else if (fkScore < 50) {
      issues.push(`${file}: Difficult to read (FK: ${fkScore})`);
    }
    
    totalScore += Math.min(100, fkScore);
  }
  
  const avgScore = totalScore / docFiles.length;
  
  return {
    score: Math.round(avgScore),
    details: `Average Flesch-Kincaid score: ${avgScore.toFixed(1)}`,
    issues,
  };
}

function calculateFleschKincaid(text: string): number {
  const sentences = text.split(/[.!?]+/).filter(Boolean).length;
  const words = text.split(/\s+/).filter(Boolean).length;
  const syllables = countSyllables(text);
  
  if (sentences === 0 || words === 0) return 0;
  
  return 206.835 - 1.015 * (words / sentences) - 84.6 * (syllables / words);
}
```

### Link Validation

```typescript
async function validateLinks(): Promise<QualityIssue[]> {
  const issues: QualityIssue[] = [];
  const docFiles = await glob('**/*.md', { ignore: ['node_modules/**'] });
  
  for (const file of docFiles) {
    const content = await readFile(file);
    
    // Find all links
    const internalLinks = content.match(/\[.*?\]\(((?!http)[^)]+)\)/g) || [];
    const externalLinks = content.match(/\[.*?\]\((https?:\/\/[^)]+)\)/g) || [];
    
    // Check internal links
    for (const link of internalLinks) {
      const path = link.match(/\]\(([^)]+)\)/)?.[1];
      if (path && !await exists(path)) {
        issues.push({
          file,
          type: 'broken-link',
          severity: 'high',
          message: `Broken internal link: ${path}`,
        });
      }
    }
    
    // Check external links (optional, can be slow)
    // for (const link of externalLinks) { ... }
  }
  
  return issues;
}
