### Phase 4: Generate Attribution File

**If `--fix-auto`:**
```typescript
async function generateAttributionFile(deps: Dependency[]): Promise<void> {
  let content = '# Open Source Attributions\n\n';
  content += 'This project uses the following open-source packages:\n\n';
  
  // Group by license
  const byLicense = deps.reduce((acc, dep) => {
    if (!acc[dep.license]) acc[dep.license] = [];
    acc[dep.license].push(dep);
    return acc;
  }, {} as Record<string, Dependency[]>);
  
  for (const [license, packages] of Object.entries(byLicense)) {
    content += `## ${license}\n\n`;
    
    for (const pkg of packages) {
      content += `### ${pkg.name} (${pkg.version})\n`;
      content += `- **License:** ${pkg.license}\n`;
      if (pkg.copyright) content += `- **Copyright:** ${pkg.copyright}\n`;
      if (pkg.repository) content += `- **Repository:** ${pkg.repository}\n`;
      content += '\n';
    }
  }
  
  await writeFile('ATTRIBUTION.md', content);
}
```

