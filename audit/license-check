## 🛠️ Implementation Phases

### Phase 1: Scan Dependencies

**Extract all dependencies:**
```bash
# Use license-checker npm package
npx license-checker --json --production > /tmp/licenses.json
```

**Parse licenses:**
```typescript
interface Dependency {
  name: string;
  version: string;
  license: string;
  repository: string;
  publisher: string;
  copyright: string;
}

async function scanDependencies(): Promise<Dependency[]> {
  const licenseData = JSON.parse(await readFile('/tmp/licenses.json'));
  
  return Object.entries(licenseData).map(([key, value]: any) => ({
    name: key.split('@')[0],
    version: key.split('@')[1],
    license: value.licenses,
    repository: value.repository,
    publisher: value.publisher,
    copyright: value.copyright,
  }));
}
```

---

### Phase 2: Classify License Risk

**Risk assessment:**
```typescript
type RiskLevel = 'red' | 'yellow' | 'green';

const LICENSE_RISK_MAP: Record<string, RiskLevel> = {
  // Green (permissive)
  'MIT': 'green',
  'Apache-2.0': 'green',
  'BSD-2-Clause': 'green',
  'BSD-3-Clause': 'green',
  'ISC': 'green',
  '0BSD': 'green',
  'CC0-1.0': 'green',
  
  // Yellow (weak copyleft)
  'MPL-2.0': 'yellow',
  'LGPL-2.1': 'yellow',
  'LGPL-3.0': 'yellow',
  'EPL-2.0': 'yellow',
  
  // Red (strong copyleft)
  'GPL-2.0': 'red',
  'GPL-3.0': 'red',
  'AGPL-3.0': 'red',
  'CC-BY-SA': 'red',
  'UNLICENSED': 'red',
};

function classifyRisk(license: string): RiskLevel {
  return LICENSE_RISK_MAP[license] || 'yellow'; // Unknown = yellow
}
```

---

### Phase 3: Check License Compatibility

**Compatibility matrix:**
```typescript
function checkCompatibility(
  projectLicense: string,
  dependencyLicense: string
): { compatible: boolean; reason?: string } {
  
  // MIT/Apache can use almost everything except GPL
  if (['MIT', 'Apache-2.0'].includes(projectLicense)) {
    if (['GPL-2.0', 'GPL-3.0', 'AGPL-3.0'].includes(dependencyLicense)) {
      return {
        compatible: false,
        reason: 'GPL/AGPL forces entire project to be GPL/AGPL',
      };
    }
  }
  
  // GPL can use MIT/Apache/BSD (they become GPL)
  if (projectLicense.startsWith('GPL')) {
    if (['MIT', 'Apache-2.0', 'BSD-2-Clause', 'BSD-3-Clause', 'ISC'].includes(dependencyLicense)) {
      return { compatible: true };
    }
  }
  
  return { compatible: true };
}
```

