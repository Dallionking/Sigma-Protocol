## 📋 Actionable Task List (Auto-Generated)

```typescript
async function generateActionableTasks(gaps: ImplementationGap[]): Promise<void> {
  if (!params.generateTodos) return;
  
  const todos = gaps
    .filter(g => !g.autoFixed && (g.severity === 'critical' || g.severity === 'high'))
    .map(g => ({
      id: `gap-${g.id}`,
      content: `[POST-IMPLEMENTATION] ${g.title}: ${g.description}`,
      status: g.autoFixed ? 'completed' : 'pending' as const,
    }));
  
  await todo_write({ merge: false, todos });
  
  console.log(`\n✅ Generated ${todos.length} actionable tasks`);
  console.log(`   ${gaps.filter(g => g.autoFixed).length} gaps auto-fixed`);
  console.log(`   Run @status to see workflow integration`);
}
```

## 🔄 Workflow Integration

```typescript
async function integrateWithStatus(gaps: ImplementationGap[]): Promise<void> {
  if (!params.workflowIntegration) return;
  
  // Read current status
  const statusReport = await readFile('docs/status/WORKFLOW-STATUS.md').catch(() => null);
  
  // Update status based on gap analysis results
  const criticalGaps = gaps.filter(g => g.severity === 'critical' && !g.autoFixed);
  const allGapsFixed = gaps.every(g => g.autoFixed || g.severity === 'low');
  
  if (criticalGaps.length > 0) {
    await updateStatus({
      step: 11,
      status: 'needs-fix',
      reason: `${criticalGaps.length} critical gaps found in implementation`,
      action: 'Review @gap-analysis report and fix remaining gaps',
    });
  } else if (allGapsFixed) {
    await updateStatus({
      step: 11,
      status: 'complete',
      reason: 'All gaps resolved - ready for deployment',
      action: 'Proceed with @ship-check',
    });
  }
  
  console.log('\n✅ Integrated with @status workflow tracking');
}
```

