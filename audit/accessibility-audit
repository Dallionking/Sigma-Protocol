interface WCAG22Criteria {
  // New in WCAG 2.2
  '2.4.11': {
    name: 'Focus Not Obscured (Minimum)';
    level: 'AA';
    description: 'When a user interface component receives keyboard focus, the component is not entirely hidden due to author-created content.';
    test: () => Promise<TestResult>;
  };
  '2.4.12': {
    name: 'Focus Not Obscured (Enhanced)';
    level: 'AAA';
    description: 'When a user interface component receives keyboard focus, no part of the component is hidden by author-created content.';
    test: () => Promise<TestResult>;
  };
  '2.4.13': {
    name: 'Focus Appearance';
    level: 'AAA';
    description: 'Focus indicators have sufficient size and contrast.';
    test: () => Promise<TestResult>;
  };
  '2.5.7': {
    name: 'Dragging Movements';
    level: 'AA';
    description: 'All functionality that uses dragging can be achieved without dragging.';
    test: () => Promise<TestResult>;
  };
  '2.5.8': {
    name: 'Target Size (Minimum)';
    level: 'AA';
    description: 'Interactive elements have a minimum target size of 24x24 CSS pixels.';
    test: () => Promise<TestResult>;
  };
  '3.2.6': {
    name: 'Consistent Help';
    level: 'A';
    description: 'Help mechanisms occur in the same relative order on each page.';
    test: () => Promise<TestResult>;
  };
  '3.3.7': {
    name: 'Redundant Entry';
    level: 'A';
    description: 'Information previously entered is auto-populated or available for selection.';
    test: () => Promise<TestResult>;
  };
  '3.3.8': {
    name: 'Accessible Authentication (Minimum)';
    level: 'AA';
    description: 'Authentication does not require cognitive function tests.';
    test: () => Promise<TestResult>;
  };
  '3.3.9': {
    name: 'Accessible Authentication (Enhanced)';
    level: 'AAA';
    description: 'No cognitive function test required for any authentication step.';
    test: () => Promise<TestResult>;
  };
}

async function testWCAG22Criteria(): Promise<WCAG22Results> {
  const results: WCAG22Results = {
    passed: [],
    failed: [],
    warnings: [],
  };
  
  // 2.4.11: Focus Not Obscured
  const focusObscuredResult = await testFocusNotObscured();
  if (focusObscuredResult.passed) {
    results.passed.push('2.4.11');
  } else {
    results.failed.push({
      criterion: '2.4.11',
      elements: focusObscuredResult.failingElements,
      fix: 'Ensure focused elements are not covered by sticky headers, modals, or other overlays',
    });
  }
  
  // 2.5.7: Dragging Movements
  const draggingResult = await testDraggingAlternatives();
  if (draggingResult.passed) {
    results.passed.push('2.5.7');
  } else {
    results.failed.push({
      criterion: '2.5.7',
      elements: draggingResult.failingElements,
      fix: 'Provide keyboard/button alternatives for drag-and-drop interactions',
    });
  }
  
  // 2.5.8: Target Size
  const targetSizeResult = await testTargetSize(24); // 24px minimum for AA
  if (targetSizeResult.passed) {
    results.passed.push('2.5.8');
  } else {
    results.failed.push({
      criterion: '2.5.8',
      elements: targetSizeResult.failingElements,
      fix: 'Increase target size to minimum 24x24 CSS pixels',
    });
  }
  
  // 3.3.8: Accessible Authentication
  const authResult = await testAccessibleAuthentication();
  if (authResult.passed) {
    results.passed.push('3.3.8');
  } else {
    results.warnings.push({
      criterion: '3.3.8',
      message: 'Review authentication flow for cognitive function tests (CAPTCHAs, puzzles)',
    });
  }
  
  return results;
}
```

### Focus Not Obscured Testing

```typescript
async function testFocusNotObscured(): Promise<TestResult> {
  const failingElements: string[] = [];
  
  // Find all focusable elements
  const focusableElements = await page.$$eval(
    'a, button, input, select, textarea, [tabindex]:not([tabindex="-1"])',
    elements => elements.map(el => ({
      selector: getSelector(el),
      rect: el.getBoundingClientRect(),
    }))
  );
  
  // Find sticky/fixed elements that could obscure focus
  const stickyElements = await page.$$eval(
    '[style*="position: fixed"], [style*="position: sticky"], .fixed, .sticky',
    elements => elements.map(el => ({
      selector: getSelector(el),
      rect: el.getBoundingClientRect(),
    }))
  );
  
  // Test each focusable element
  for (const focusable of focusableElements) {
    await page.focus(focusable.selector);
    
    // Check if any sticky element obscures the focused element
    for (const sticky of stickyElements) {
      if (isObscured(focusable.rect, sticky.rect)) {
        failingElements.push(focusable.selector);
        break;
      }
    }
  }
  
  return {
    passed: failingElements.length === 0,
    failingElements,
  };
}
```

