```typescript
async function reportToStatus(audit: AuditResult): Promise<void> {
  const statusData = {
    command: '@accessibility-audit',
    lastRun: new Date().toISOString(),
    result: audit.score >= 90 ? 'success' : audit.score >= 70 ? 'needs-attention' : 'critical',
    metrics: {
      overallScore: audit.score,
      criticalIssues: audit.issues.filter(i => i.severity === 'critical').length,
      mobileScore: audit.mobileScore || 0,
      wcagLevel: audit.level,
    },
    milestone: audit.milestoneProgress || null,
  };
  
  const statusPath = '/docs/.command-status.json';
  let commandStatus = {};
  try {
    commandStatus = JSON.parse(await readFile(statusPath));
  } catch {
    commandStatus = {};
  }
  
  commandStatus['@accessibility-audit'] = statusData;
  await writeFile(statusPath, JSON.stringify(commandStatus, null, 2));
}
