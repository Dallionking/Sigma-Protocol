## 📊 Tracking Integration

**After verification, update `.tracking-db/prds/[PRD-ID].json`:**

```typescript
async function updateTrackingState(prdId: string, score: number, grade: string) {
  const trackingPath = `.tracking-db/prds/${prdId}.json`;
  
  // Ensure directory exists
  await run_terminal_cmd('mkdir -p .tracking-db/prds');
  
  // Read existing tracking state or create new
  let tracking = {};
  try {
    const existing = await read_file(trackingPath);
    tracking = JSON.parse(existing);
  } catch {
    // New tracking file
    tracking = {
      id: prdId,
      prd_path: `docs/prds/${prdId}.md`,
      status: 'in_progress',
      created: new Date().toISOString(),
    };
  }
  
  // Update verification state
  tracking.updated = new Date().toISOString();
  tracking.implementation = tracking.implementation || {};
  tracking.implementation.verification_score = score;
  tracking.implementation.verification_grade = grade;
  tracking.implementation.last_verified = new Date().toISOString();
  
  // Update status based on score
  if (score >= 8) {
    tracking.status = 'verified';
    tracking.checkpoints = tracking.checkpoints || [];
    tracking.checkpoints.push({
      name: 'PRD Verified',
      completed: true,
      timestamp: new Date().toISOString(),
      score: score,
    });
  }
  
  // Write updated tracking
  await write(trackingPath, JSON.stringify(tracking, null, 2));
  
  console.log(`\n📊 Tracking updated: ${trackingPath}`);
  console.log(`   Score: ${score}/10 (${grade})`);
}

// Call after verification completes
await updateTrackingState(prdId, finalScore, finalGrade);
```

**Tracking Fields Updated:**
- `implementation.verification_score` - 0-10 score
- `implementation.verification_grade` - PASS/NEEDS_WORK/FAIL
- `implementation.last_verified` - ISO timestamp
- `status` - Changes to 'verified' if score ≥ 8
- `checkpoints[]` - Adds "PRD Verified" checkpoint

