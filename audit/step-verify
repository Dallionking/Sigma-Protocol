## Iterative Fix Loop (--fix mode)

When `--fix` is enabled, run up to 5 iterations to achieve 100%:

```typescript
async function iterativeFix(stepNum: number): Promise<FinalResult> {
  const MAX_ITERATIONS = 5;
  let iteration = 0;
  let result: VerificationResult;
  
  console.log(`\n🔄 Starting iterative fix for Step ${stepNum}...\n`);
  
  while (iteration < MAX_ITERATIONS) {
    iteration++;
    console.log(`━━━ Iteration ${iteration}/${MAX_ITERATIONS} ━━━\n`);
    
    // Run verification
    result = await verifyStep(stepNum, false);
    console.log(`Score: ${result.score}/100`);
    
    if (result.score === 100) {
      console.log(`\n✅ Step ${stepNum} is 100% complete!`);
      return { success: true, iterations: iteration, finalScore: 100 };
    }
    
    // Get auto-fixable gaps
    const autoFixableGaps = result.gaps.filter(g => g.autoFixable);
    
    if (autoFixableGaps.length === 0) {
      console.log(`\n⚠️ Remaining gaps require manual intervention:`);
      for (const gap of result.gaps) {
        console.log(`  - ${gap.issue}`);
        console.log(`    Fix: ${gap.fix}`);
      }
      return { 
        success: false, 
        iterations: iteration, 
        finalScore: result.score,
        manualGaps: result.gaps,
      };
    }
    
    // Apply auto-fixes
    console.log(`\n🔧 Applying ${autoFixableGaps.length} auto-fixes...`);
    for (const gap of autoFixableGaps) {
      await applyFix(gap.fixAction);
      console.log(`  ✓ Fixed: ${gap.issue}`);
    }
    
    console.log('');
  }
  
  console.log(`\n⚠️ Max iterations (${MAX_ITERATIONS}) reached. Final score: ${result.score}/100`);
  return { success: false, iterations: MAX_ITERATIONS, finalScore: result.score };
}
```

