# ===========================================
# X PROMOTER - ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your credentials
# DO NOT commit .env to version control!

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# For local development, use SQLite (leave DATABASE_URL empty)
# For production (Render), use Postgres
DATABASE_URL=

# ===========================================
# ANTHROPIC (CLAUDE) API
# ===========================================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===========================================
# X/TWITTER API CREDENTIALS - ACCOUNT 1 (Primary)
# ===========================================
# Get your credentials from: https://developer.twitter.com/
# You need Basic tier ($100/month) for posting capabilities

# Account 1 - SSS Protocol Promotion
X_ACCOUNT_1_NAME=sss-protocol
X_ACCOUNT_1_API_KEY=your_api_key_here
X_ACCOUNT_1_API_SECRET=your_api_secret_here
X_ACCOUNT_1_ACCESS_TOKEN=your_access_token_here
X_ACCOUNT_1_ACCESS_SECRET=your_access_token_secret_here
X_ACCOUNT_1_BEARER_TOKEN=your_bearer_token_here

# ===========================================
# X/TWITTER API CREDENTIALS - ACCOUNT 2 (Optional)
# ===========================================
# Uncomment and fill in to add additional accounts

# X_ACCOUNT_2_NAME=other-project
# X_ACCOUNT_2_API_KEY=
# X_ACCOUNT_2_API_SECRET=
# X_ACCOUNT_2_ACCESS_TOKEN=
# X_ACCOUNT_2_ACCESS_SECRET=
# X_ACCOUNT_2_BEARER_TOKEN=

# ===========================================
# X/TWITTER API CREDENTIALS - ACCOUNT 3 (Optional)
# ===========================================
# X_ACCOUNT_3_NAME=another-project
# X_ACCOUNT_3_API_KEY=
# X_ACCOUNT_3_API_SECRET=
# X_ACCOUNT_3_ACCESS_TOKEN=
# X_ACCOUNT_3_ACCESS_SECRET=
# X_ACCOUNT_3_BEARER_TOKEN=

# ===========================================
# APPLICATION SETTINGS
# ===========================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Environment: development, production
NODE_ENV=development

# Scheduler interval in minutes (how often to check for new tweets)
SCHEDULER_INTERVAL_MINUTES=5

# Global daily reply limit (across all accounts)
GLOBAL_DAILY_LIMIT=300

# Minimum minutes between replies from same account
MIN_REPLY_INTERVAL_MINUTES=5


