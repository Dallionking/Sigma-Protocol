{
  "name": "@sigma-protocol/x-promoter",
  "version": "1.0.0",
  "type": "module",
  "description": "Automated X/Twitter promotion system with multi-account support - Part of Sigma Protocol",
  "main": "dist/index.js",
  "bin": {
    "x-promoter": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && npm run copy-config",
    "copy-config": "cp -r src/config dist/",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "cli": "tsx src/cli.ts",
    "db:migrate": "tsx src/utils/migrate.ts",
    "db:seed": "tsx src/utils/seed.ts",
    "test": "vitest"
  },
  "keywords": [
    "twitter",
    "x",
    "automation",
    "promotion",
    "ai",
    "sigma-protocol"
  ],
  "author": "Dallion King",
  "license": "MIT",
  "dependencies": {
    "twitter-api-v2": "^1.17.2",
    "@anthropic-ai/sdk": "^0.32.1",
    "commander": "^12.1.0",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "better-sqlite3": "^11.6.0",
    "dotenv": "^16.4.7",
    "winston": "^3.17.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.1",
    "inquirer": "^12.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "@types/better-sqlite3": "^7.6.12",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

