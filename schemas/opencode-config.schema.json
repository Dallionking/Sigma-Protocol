{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sigma-protocol.dev/schemas/opencode-config.schema.json",
  "title": "OpenCode Configuration",
  "description": "Schema for opencode.json configuration file generated by Sigma Protocol",
  "type": "object",
  "required": ["$schema", "name", "version"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to OpenCode config schema",
      "const": "https://opencode.ai/config.json"
    },
    "name": {
      "type": "string",
      "description": "Project name",
      "minLength": 1,
      "maxLength": 100
    },
    "version": {
      "type": "string",
      "description": "Configuration version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "agents": {
      "type": "object",
      "description": "Agent configurations",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "model": {
            "type": "string",
            "description": "Model identifier (e.g., anthropic/claude-sonnet-4-20250514)"
          },
          "temperature": {
            "type": "number",
            "minimum": 0,
            "maximum": 2,
            "description": "Model temperature setting"
          }
        }
      }
    },
    "tools": {
      "type": "object",
      "description": "Custom tool configurations",
      "additionalProperties": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Path to tool implementation file"
          }
        }
      }
    }
  },
  "additionalProperties": true
}
